---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title} — Mr. Audio Feedback</title>
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
<style is:global>
  :root {
    --amber: #ffb700;
    --amber-dim: #b88800;
    --amber-glow: rgba(255, 183, 0, 0.15);
    --cyan: #00f5ff;
    --cyan-dim: #00aabb;
    --magenta: #ff2d78;
    --bg: #070705;
    --bg2: #0d0d09;
    --text: #e8d5a3;
    --text-dim: #a89880;
    --green: #39ff14;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
    cursor: url('/cursors/cursor-arrow.png') 0 0, auto;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
    z-index: 9998;
  }
  
  a:focus-visible, button:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 4px;
  }

  a, button {
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
  }

  p, article, input, textarea {
    cursor: url('/cursors/cursor-text.png') 6 16, text;
  }

   .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1px solid var(--amber);
    color: var(--amber);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    letter-spacing: 2px;
    text-decoration: none;
    transition: all 0.2s;
    background: transparent;
    align-self: flex-start;
  }

  .btn:hover {
    background: var(--amber);
    color: var(--bg);
    box-shadow: 0 0 20px rgba(255,183,0,0.4);
  }

  .skip-link {
    position: absolute;
    top: -100px;
    left: 16px;
    background: var(--amber);
    color: var(--bg);
    padding: 8px 16px;
    font-size: 14px;
    font-family: 'Share Tech Mono', monospace;
    text-decoration: none;
    z-index: 99999;
    transition: top 0.2s;
  }

  .skip-link:focus { top: 16px; }

  /* ── Nav ── */
  nav {
    border-bottom: 1px solid var(--amber-dim);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background: rgba(7,7,5,0.95);
    backdrop-filter: blur(4px);
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-family: 'VT323', monospace;
    font-size: 26px;
    color: var(--amber);
    text-shadow: 0 0 20px var(--amber), 0 0 40px rgba(255,183,0,0.3);
    text-decoration: none;
    letter-spacing: 2px;
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
  }

  .nav-logo span { color: var(--cyan); }

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}

.nav-links a {
  text-decoration: none;
  font-size: 16px;
  letter-spacing: 1px;
  transition: color 0.2s;
}

.nav-links a:link,
.nav-links a:visited {
  color: var(--text-dim);
  text-decoration: none;
}

.nav-links a::before {
  content: '> ';
  color: var(--amber);
  opacity: 0;
  transition: opacity 0.2s;
}

.nav-links a:hover {
  color: var(--amber);
  text-decoration: none;
}

.nav-links a:hover::before { opacity: 1; }

  /* ── Container ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .content-header-inner {
    display: flex;
    gap: 32px;
    align-items: center;
    margin-top: 24px;
  }

  .content-thumb {
    width: 40%;
    flex-shrink: 0;
    aspect-ratio: 16/9;
    overflow: hidden;
    border: 1px solid var(--amber-dim);
    position: relative;
    overflow: hidden;
  }

  .content-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8) saturate(0.7);
  }

  .content-header-text {
    flex: 1;
  }

  /* Header */
  .content-header {
    padding: 60px 0 40px;
    border-bottom: 1px solid rgba(255,183,0,0.1);
  }

  .content-breadcrumb {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 20px;
    letter-spacing: 1px;
  }

  .content-breadcrumb a {
    color: var(--amber-dim);
    text-decoration: none;
  }

  .content-breadcrumb a:hover { color: var(--amber); }

  .content-type {
    font-size: 14px;
    color: var(--cyan);
    letter-spacing: 3px;
    margin-bottom: 16px;
  }

  .content-title {
    font-family: 'VT323', monospace;
    font-size: clamp(32px, 5vw, 56px);
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .content-meta {
    display: flex;
    gap: 5px;
    align-items: center;
    font-size: 14px;
    color: var(--text-dim);
  }

  .content-meta .dot {
    color: var(--amber);
    width: 8px;
    height: 8px;
    background: var(--amber);
    display: inline-block;
    flex-shrink: 0;
    align-self: center;
  }

  .content-meta .after-dot {
    margin-right: 10px;
    display: inline-flex;
    align-items: center;
  }

  /* Video */
  .video-section {
    padding: 48px 0 0;
  }

  .video-label {
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .video-label span { color: var(--green); }

  .video-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--bg2);
    border: 1px solid var(--amber-dim);
    overflow: hidden;
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: linear-gradient(135deg, #0a0a0a, #001a1a);
  }

  .video-placeholder-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,183,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,183,0,0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .video-placeholder p {
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
    position: relative;
    z-index: 1;
  }

  /* Divider */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 48px 0 40px;
  }

  .section-divider span {
    font-family: 'VT323', monospace;
    font-size: 22px;
    color: var(--amber);
    letter-spacing: 3px;
    white-space: nowrap;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--amber-dim), transparent);
  }

  /* Post content */
  .post-content {
    padding-bottom: 80px;
  }

  .post-content h2 {
    font-family: 'VT323', monospace;
    font-size: 32px;
    color: var(--amber);
    letter-spacing: 2px;
    margin: 48px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255,183,0,0.15);
  }

  .post-content h3 {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--cyan);
    letter-spacing: 1px;
    margin: 32px 0 12px;
  }

  .post-content p {
    color: var(--text);
    font-size: 16px;
    line-height: 1.9;
    margin-bottom: 24px;
  }

  .post-content ul, .post-content ol {
    padding-left: 24px;
    margin-bottom: 24px;
  }

  .post-content li {
    color: var(--text);
    font-size: 16px;
    line-height: 1.9;
    margin-bottom: 8px;
  }

  .post-content li::marker { color: var(--amber); }

  .post-content a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content a:hover { color: var(--amber); }

  .post-content code {
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    background: var(--bg2);
    color: var(--green);
    padding: 2px 8px;
    border: 1px solid rgba(255,183,0,0.15);
  }

  .post-content pre {
    background: #050503;
    border: 1px solid var(--amber-dim);
    padding: 24px;
    margin: 24px 0;
    overflow-x: auto;
    position: relative;
  }

  .post-content pre::before {
    content: '● ● ●';
    display: block;
    font-size: 10px;
    color: var(--amber-dim);
    letter-spacing: 4px;
    margin-bottom: 16px;
  }

  .post-content pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    color: var(--text);
    line-height: 1.8;
  }

  .post-content blockquote {
    border-left: 3px solid var(--amber);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--text-dim);
    font-style: italic;
  }


  /* ── Main ── */
  main {
    min-height: calc(100vh - 200px);
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid rgba(255,183,0,0.1);
    padding: 40px 0;
    margin-top: 60px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'VT323', monospace;
    font-size: 22px;
    color: var(--amber-dim);
    letter-spacing: 2px;
  }

  .footer-text {
    font-size: 14px;
    color: var(--text-dim);
    text-align: right;
    line-height: 1.8;
  }

  .footer-text a { color: var(--amber-dim); text-decoration: none; }
  .footer-text a:hover { color: var(--amber); }

  /* ── Shared page header ── */
  .page-header {
    padding: 60px 0 40px;
    border-bottom: 1px solid rgba(255,183,0,0.1);
  }

  .page-breadcrumb {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 2rem;
    letter-spacing: 1px;
  }

  .page-breadcrumb a {
    color: var(--amber-dim);
    text-decoration: none;
  }

  .page-breadcrumb a:hover { color: var(--amber); }

  .page-type {
    font-size: 14px;
    color: var(--cyan);
    letter-spacing: 3px;
    margin-bottom: 12px;
  }

  .page-title {
    font-family: 'VT323', monospace;
    font-size: clamp(48px, 7vw, 80px);
    color: var(--amber);
    line-height: 1;
    letter-spacing: 4px;
    text-shadow: 0 0 30px rgba(255,183,0,0.3);
    margin-bottom: 16px;
  }

  .page-desc {
    font-size: 16px;
    color: var(--text-dim);
    max-width: 600px;
    border-left: 2px solid var(--amber-dim);
    padding-left: 16px;
    line-height: 1.8;
    margin-top: 16px;
  }

  /* ── Shared section styles ── */
  section { padding: 48px 0 80px; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .section-header h2 {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--amber);
    letter-spacing: 3px;
    white-space: nowrap;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--amber-dim), transparent);
  }

  .section-count {
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 2px;
    border: 1px solid var(--amber-dim);
    padding: 2px 8px;
  }

  /* ── Shared card styles ── */
  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 10px;
  }

  .card {
    background: var(--bg2);
    border: 1px solid rgba(255,183,0,0.12);
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    color: inherit;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--amber-glow) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .card:hover {
    border-color: var(--amber);
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(255,183,0,0.1), 0 0 1px var(--amber);
  }

  .card:visited { color: var(--amber);}

  .card:hover::before { opacity: 1; }

  .card-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a0a 0%, #001a1a 100%);
  }

  .card-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) saturate(0.6);
    transition: filter 0.3s;
  }

  .card:hover .card-thumb img { filter: brightness(0.85) saturate(0.8); }

  .thumb-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(0,0,0,0.35) 2px, rgba(0,0,0,0.35) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .thumb-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,183,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,183,0,0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .thumb-label {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0,0,0,0.8);
    color: var(--cyan);
    font-size: 14px;
    padding: 2px 6px;
    border: 1px solid var(--cyan-dim);
    z-index: 2;
  }

  .card-body {
    padding: 20px; 
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-date { font-size: 14px; color: var(--text-dim); letter-spacing: 1px; }

  .card-tag {
    font-size: 14px;
    color: var(--cyan);
    letter-spacing: 1px;
    border: 1px solid rgba(0,245,255,0.3);
    padding: 1px 6px;
  }

  .card-title {
    font-family: 'VT323', monospace;
    font-size: 22px;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 8px;
    transition: color 0.2s;
  }

  .card:hover .card-title { color: var(--amber); }

  .card-desc {
    font-size: 15px;
    color: var(--text-dim);
    line-height: 1.6;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,183,0,0.08);
    font-size: 14px;
    color: var(--text-dim);
  }

  .card-footer .dot {
    color: var(--amber);
    width: 8px;
    height: 8px;
    background: var(--amber);
    display: inline-block;
    flex-shrink: 0;
    align-self: center;  
  }

  .content-footer .after-dot {
    margin-right: 10px;
    display: inline-flex;
    align-items: center;
  }

  /* ── Empty state ── */
  .empty-state {
    padding: 80px 0;
    text-align: center;
    color: var(--text-dim);
  }

  .empty-title {
    font-family: 'VT323', monospace;
    font-size: 32px;
    color: var(--amber-dim);
    margin-bottom: 12px;
  }

  /* Nav footer */
  .content-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-bottom: 60px;
    width: 100%;
  }

  .content-nav a {
    text-decoration: none;
    color: inherit;
  }

  .content-nav a:link,
  .content-nav a:visited {
    color: inherit;
    text-decoration: none;
  }

  .content-nav a:hover {
    color: var(--amber);
    text-decoration: none;
  }

  .content-nav-item {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
  }

  .content-nav-item.next {
    display: flex;
    justify-content: flex-end;
    text-align: right;
  }

  .content-nav-item.next span {
    text-align: right;
  }

  .nav-direction {
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .nav-title h2 {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--amber);
    transition: color 0.2s;
  }

  .nav-title a {
    text-decoration: none;
  }

  .nav-title h2:hover { color: var(--amber-dim); }

  /* ── Other types nav ── */
  .other-types { padding: 0 0 80px; }

  .type-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .type-link {
    font-size: 14px;
    letter-spacing: 2px;
    padding: 6px 16px;
    border: 1px solid var(--amber-dim);
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.2s;
  }

  .type-link:hover {
    border-color: var(--amber);
    color: var(--amber);
    background: var(--amber-glow);
  }

  .type-link:visited:hover {
    border-color: var(--amber);
    color: var(--amber);
    background: var(--amber-glow);
  }

  /* ── Animations ── */
  @media (prefers-reduced-motion: no-preference) {
    body { animation: flicker 9s ease infinite; }
  }

  @keyframes flicker {
    0%, 98%, 100% { opacity: 1; }
    99% { opacity: 0.96; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .nav-links { gap: 16px; }
    .type-links { gap: 6px; }
  }

  @media (max-width: 480px) {
    .nav-links { display: none; }
    .content-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>