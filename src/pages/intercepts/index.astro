---
import { getCollection } from 'astro:content';

const intercepts = await getCollection('intercepts');
const sorted = intercepts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Intercepts — Mr. Audio Feedback</title>
<meta name="description" content="Step-by-step self-hosting tutorials and how-to guides. Own your stack." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link href="https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
<style>
  :root {
    --amber: #ffb700;
    --amber-dim: #b88800;
    --amber-glow: rgba(255, 183, 0, 0.15);
    --cyan: #00f5ff;
    --cyan-dim: #00aabb;
    --magenta: #ff2d78;
    --bg: #070705;
    --bg2: #0d0d09;
    --text: #e8d5a3;
    --text-dim: #a89880;
    --green: #39ff14;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
    cursor: url('/cursors/cursor-arrow.png') 0 0, auto;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
    z-index: 9998;
  }

  a:focus-visible, button:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 4px;
  }

  .skip-link {
    position: absolute;
    top: -100px;
    left: 16px;
    background: var(--amber);
    color: var(--bg);
    padding: 8px 16px;
    font-size: 14px;
    font-family: 'Share Tech Mono', monospace;
    text-decoration: none;
    z-index: 99999;
    transition: top 0.2s;
  }

  .skip-link:focus { top: 16px; }

  nav {
    border-bottom: 1px solid var(--amber-dim);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background: rgba(7,7,5,0.95);
    backdrop-filter: blur(4px);
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-family: 'VT323', monospace;
    font-size: 26px;
    color: var(--amber);
    text-shadow: 0 0 20px var(--amber), 0 0 40px rgba(255,183,0,0.3);
    text-decoration: none;
    letter-spacing: 2px;
  }

  .nav-logo span { color: var(--cyan); }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 16px;
    letter-spacing: 1px;
    transition: color 0.2s;
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
  }

  .nav-links a::before {
    content: '> ';
    color: var(--amber);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .nav-links a:hover { color: var(--amber); }
  .nav-links a:hover::before { opacity: 1; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .page-header {
    padding: 60px 0 40px;
    border-bottom: 1px solid rgba(255,183,0,0.1);
  }

  .page-breadcrumb {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  .page-breadcrumb a {
    color: var(--amber-dim);
    text-decoration: none;
  }

  .page-breadcrumb a:hover { color: var(--amber); }

  .page-type {
    font-size: 14px;
    color: var(--cyan);
    letter-spacing: 3px;
    margin-bottom: 12px;
  }

  .page-title {
    font-family: 'VT323', monospace;
    font-size: clamp(48px, 7vw, 80px);
    color: var(--amber);
    line-height: 1;
    letter-spacing: 4px;
    text-shadow: 0 0 30px rgba(255,183,0,0.3);
    margin-bottom: 16px;
  }

  .page-desc {
    font-size: 16px;
    color: var(--text-dim);
    max-width: 600px;
    border-left: 2px solid var(--amber-dim);
    padding-left: 16px;
    line-height: 1.8;
    margin-top: 16px;
  }

  .content-section {
    padding: 48px 0 80px;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .section-header h2 {
    font-family: 'VT323', monospace;
    font-size: 24px;
    color: var(--amber);
    letter-spacing: 3px;
    white-space: nowrap;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--amber-dim), transparent);
  }

  .section-count {
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 2px;
    border: 1px solid var(--amber-dim);
    padding: 2px 8px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
  }

  .card {
    background: var(--bg2);
    border: 1px solid rgba(255,183,0,0.12);
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    display: block;
    color: inherit;
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--amber-glow) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .card:hover {
    border-color: var(--amber);
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(255,183,0,0.1), 0 0 1px var(--amber);
  }

  .card:hover::before { opacity: 1; }

  .card-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0a0a0a 0%, #001a1a 100%);
  }

  .card-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) saturate(0.6);
    transition: filter 0.3s;
  }

  .card:hover .card-thumb img {
    filter: brightness(0.85) saturate(0.8);
  }

  .thumb-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.35) 2px,
      rgba(0,0,0,0.35) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .thumb-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,183,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,183,0,0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .play-icon {
    width: 48px;
    height: 48px;
    border: 2px solid var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber);
    font-size: 18px;
    box-shadow: 0 0 20px rgba(255,183,0,0.3);
    transition: all 0.2s;
    position: relative;
    z-index: 2;
  }

  .card:hover .play-icon {
    transform: scale(1.08);
    box-shadow: 0 0 30px rgba(255,183,0,0.5);
  }

  .thumb-label {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0,0,0,0.8);
    color: var(--cyan);
    font-size: 14px;
    padding: 2px 6px;
    border: 1px solid var(--cyan-dim);
    z-index: 2;
  }

  .card-body { padding: 20px; }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .card-date { font-size: 14px; color: var(--text-dim); letter-spacing: 1px; }

  .card-tag {
    font-size: 14px;
    color: var(--cyan);
    letter-spacing: 1px;
    border: 1px solid rgba(0,245,255,0.3);
    padding: 1px 6px;
  }

  .card-title {
    font-family: 'VT323', monospace;
    font-size: 22px;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 8px;
    transition: color 0.2s;
  }

  .card:hover .card-title { color: var(--amber); }

  .card-desc { font-size: 15px; color: var(--text-dim); line-height: 1.6; }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,183,0,0.08);
    font-size: 14px;
    color: var(--text-dim);
  }

  .card-footer .dot { color: var(--amber); }

  .empty-state {
    padding: 80px 0;
    text-align: center;
    color: var(--text-dim);
  }

  .empty-state .empty-title {
    font-family: 'VT323', monospace;
    font-size: 32px;
    color: var(--amber-dim);
    margin-bottom: 12px;
  }

  .other-types {
    padding: 0 0 80px;
  }

  .type-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .type-link {
    font-size: 14px;
    letter-spacing: 2px;
    padding: 6px 16px;
    border: 1px solid var(--amber-dim);
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.2s;
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
  }

  .type-link:hover {
    border-color: var(--amber);
    color: var(--amber);
    background: var(--amber-glow);
  }

  footer {
    border-top: 1px solid rgba(255,183,0,0.1);
    padding: 40px 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'VT323', monospace;
    font-size: 22px;
    color: var(--amber-dim);
    letter-spacing: 2px;
  }

  .footer-text {
    font-size: 14px;
    color: var(--text-dim);
    text-align: right;
    line-height: 1.8;
  }

  .footer-text a { color: var(--amber-dim); text-decoration: none; }
  .footer-text a:hover { color: var(--amber); }

  @media (prefers-reduced-motion: no-preference) {
    body { animation: flicker 9s ease infinite; }
  }

  @keyframes flicker {
    0%, 98%, 100% { opacity: 1; }
    99% { opacity: 0.96; }
  }

  @media (max-width: 768px) {
    .nav-links { gap: 16px; }
    .type-links { gap: 6px; }
  }

  @media (max-width: 480px) {
    .nav-links { display: none; }
    .content-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<a href="#content" class="skip-link">Skip to content</a>

<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">MR. AUDIO <span>FEEDBACK</span></a>
      <ul class="nav-links">
        <li><a href="/#latest">_LATEST</a></li>
        <li><a href="/#archive">_ARCHIVE</a></li>
        <li><a href="/#about">_ABOUT</a></li>
        <li><a href="/rss.xml">_RSS</a></li>
        <li><a href="https://youtube.com/@mraudiofeedback" target="_blank" aria-label="Mr. Audio Feedback on YouTube (opens in new tab)">_YOUTUBE</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container">

  <header class="page-header">
    <div class="page-breadcrumb">
      <a href="/">~/</a> / intercepts
    </div>
    <div class="page-type">// CONTENT TYPE</div>
    <h1 class="page-title">⚙️ interceptS</h1>
    <p class="page-desc">
      Step-by-step tutorials and how-to guides for self-hosting, Docker, and owning your own stack.
      Follow along and own your infrastructure.
    </p>
  </header>

  <section class="content-section" id="content">
    <div class="section-header">
      <h2>// ALL interceptS</h2>
      <div class="section-line"></div>
      <div class="section-count">{sorted.length} ENTRIES</div>
    </div>

    {sorted.length > 0 ? (
      <div class="content-grid">
        {sorted.map((entry) => (
          <a href={`/intercepts/${entry.id.replace(/\.md$/, '')}`} class="card">
            <div class="card-thumb">
              {entry.data.youtubeId ? (
                <img
                  src={`https://img.youtube.com/vi/${entry.data.youtubeId}/maxresdefault.jpg`}
                  alt={entry.data.title}
                  loading="lazy"
                />
              ) : (
                <div class="thumb-grid"></div>
              )}
              <div class="thumb-scanlines"></div>
              <div class="play-icon">▶</div>
              <div class="thumb-label">intercept_{entry.data.number}</div>
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class="card-date">{entry.data.date}</span>
                <span class="card-tag">intercept</span>
              </div>
              <h2 class="card-title">{entry.data.title}</h2>
              <p class="card-desc">{entry.data.desc}</p>
              <div class="card-footer">
                <span class="dot">■</span> watch
                <span class="dot">■</span> read
                <span class="dot">■</span> intercept_{entry.data.number}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-title">// NO ENTRIES YET</div>
        <p>Check back soon — intercepts are being written.</p>
      </div>
    )}
  </section>

  <div class="other-types">
    <div class="section-header">
      <h2>// EXPLORE OTHER TYPES</h2>
      <div class="section-line"></div>
    </div>
    <div class="type-links">
      <a href="/signals" class="type-link">📡 SIGNALS</a>
      <a href="/protocols" class="type-link">⚙️ PROTOCOLS</a>
      <a href="/artifacts" class="type-link">📼 ARTIFACTS</a>
      <a href="/dispatches" class="type-link">🛠️ DISPATCHES</a>
    </div>
  </div>

</div>

<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-logo">MR. AUDIO <span style="color:var(--cyan)">FEEDBACK</span></div>
      <div class="footer-text">
        NO TRACKERS. NO COOKIES. NO ALGORITHMS.<br />
        <a href="/rss.xml">RSS</a> · <a href="https://youtube.com/@mraudiofeedback" target="_blank">YOUTUBE</a> · BUILT WITH INTENTION
      </div>
    </div>
  </div>
</footer>

</body>
</html>