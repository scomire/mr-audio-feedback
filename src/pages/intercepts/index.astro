---
import Base from '../../layouts/Base.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('intercepts');
---

<Base title="Intercepts" description="Deconstructions of big tech, surveillance capitalism, and the systems that shape your digital life.">
  <CategoryIndex
    {entries}
    title="INTERCEPTS"
    desc="Deconstructions of big tech, surveillance capitalism, and the systems that shape your digital life."
    emoji="👁️"
    typeSlug="intercepts"
    otherTypes={[
      { slug: 'signals', emoji: '📡', label: 'SIGNALS' },
      { slug: 'protocols', emoji: '⚙️', label: 'PROTOCOLS' },
      { slug: 'artifacts', emoji: '📼', label: 'ARTIFACTS' },
      { slug: 'dispatches', emoji: '🛠️', label: 'DISPATCHES' },
    ]}
  />
</Base>