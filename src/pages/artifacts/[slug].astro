---
import Base from '../../layouts/Base.astro';
import PostHeader from '../../components/PostHeader.astro';
import VideoSection from '../../components/VideoSection.astro';
import PostNav from '../../components/PostNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const artifacts = await getCollection('artifacts');
  return artifacts.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, youtubeId, image, desc, number, tag } = entry.data;

const artifacts = await getCollection('artifacts');
const sorted = artifacts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
const index = sorted.findIndex(p => p.id === entry.id);
const prev = sorted[index + 1] ?? null;
const next = sorted[index - 1] ?? null;
---

<Base title={title} description={desc} ogImage={youtubeId ? `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg` : image ?? null}>
  <div class="container">

    <PostHeader
      {title}
      {date}
      {number}
      {youtubeId}
      {image}
      type="ARTIFACT"
      typeSlug="artifacts"
    />

    {youtubeId && (
      <>
        <VideoSection {youtubeId} {title} />
        <div class="section-divider">
          <span>// READ THE POST</span>
          <div class="divider-line"></div>
        </div>
      </>
    )}

    <article class="post-content" id="post">
      <Content />
    </article>

    <script src="https://giscus.app/client.js"
      data-repo="scomire/mr-audio-feedback"
      data-repo-id="R_kgDORppsPA"
      data-category="Announcements"
      data-category-id="DIC_kwDORppsPM4C4zaF"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="transparent_dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async>
    </script>
    
    <PostNav {prev} {next} typeSlug="artifacts" typeLabel="artifact" />

  </div>
</Base>