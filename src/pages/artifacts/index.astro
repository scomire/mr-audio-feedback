---
import Base from '../../layouts/Base.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('artifacts');
---

<Base title="Artifacts" description="Physical media, vintage tech, and the case for owning your stuff.">
  <CategoryIndex
    {entries}
    title="ARTIFACTS"
    desc="Physical media, vintage tech, and the case for owning your stuff."
    emoji="📼"
    typeSlug="artifacts"
    otherTypes={[
      { slug: 'signals', emoji: '📡', label: 'SIGNALS' },
      { slug: 'protocols', emoji: '⚙️', label: 'PROTOCOLS' },
      { slug: 'intercepts', emoji: '👁️', label: 'INTERCEPTS' },
      { slug: 'dispatches', emoji: '🛠️', label: 'DISPATCHES' },
    ]}
  />
</Base>