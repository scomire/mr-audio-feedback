---
import Base from '../../layouts/Base.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('signals');
---

<Base title="Signals" description="Opinion, analysis, and hot takes on digital sovereignty, privacy, and owning your tech.">
  <CategoryIndex
    {entries}
    title="SIGNALS"
    desc="Opinion, analysis, and hot takes on digital sovereignty, privacy, and owning your tech."
    emoji="📡"
    typeSlug="signals"
    otherTypes={[
      { slug: 'protocols', emoji: '⚙️', label: 'PROTOCOLS' },
      { slug: 'intercepts', emoji: '👁️', label: 'INTERCEPTS' },
      { slug: 'artifacts', emoji: '📼', label: 'ARTIFACTS' },
      { slug: 'dispatches', emoji: '🛠️', label: 'DISPATCHES' },
    ]}
  />
</Base>