---
import Base from '../../layouts/Base.astro';
import PostHeader from '../../components/PostHeader.astro';
import VideoSection from '../../components/VideoSection.astro';
import PostNav from '../../components/PostNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const signals = await getCollection('signals');
  return signals.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, youtubeId, image, desc, number, tag } = entry.data;

const signals = await getCollection('signals');
const sorted = signals.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
const index = sorted.findIndex(p => p.id === entry.id);
const prev = sorted[index + 1] ?? null;
const next = sorted[index - 1] ?? null;
---

<Base title={title} description={desc}>
  <div class="container">

    <PostHeader
      {title}
      {date}
      {number}
      {youtubeId}
      {image}
      type="SIGNAL"
      typeSlug="signals"
    />

    {youtubeId && (
      <>
        <VideoSection {youtubeId} {title} />
        <div class="section-divider">
          <span>// READ THE POST</span>
          <div class="divider-line"></div>
        </div>
      </>
    )}

    <article class="post-content" id="post">
      <Content />
    </article>

    <PostNav {prev} {next} typeSlug="signals" typeLabel="SIGNAL" />

  </div>
</Base>