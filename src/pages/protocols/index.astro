---
import Base from '../../layouts/Base.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('protocols');
---

<Base title="Protocols" description="Step-by-step self-hosting tutorials and how-to guides. Own your stack.">
  <CategoryIndex
    {entries}
    title="PROTOCOLS"
    desc="Step-by-step tutorials and how-to guides for self-hosting, Docker, and owning your own stack."
    emoji="⚙️"
    typeSlug="protocols"
    otherTypes={[
      { slug: 'signals', emoji: '📡', label: 'SIGNALS' },
      { slug: 'intercepts', emoji: '👁️', label: 'INTERCEPTS' },
      { slug: 'artifacts', emoji: '📼', label: 'ARTIFACTS' },
      { slug: 'dispatches', emoji: '🛠️', label: 'DISPATCHES' },
    ]}
  />
</Base>