---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const dispatches = await getCollection('dispatches');
const sorted = dispatches.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<Base title="Dispatches" description="Field reports from the right to repair front.">

  <div class="container">

    <header class="page-header">
      <div class="page-breadcrumb">
        <a href="/">/ home</a> / <a href="/dispatches">dispatches</a>
      </div>
      <h1 class="page-title">🛠️ DISPATCHES</h1>
      <p class="page-desc">
        Field reports from the right to repair front. Fixing gear, fighting planned obsolescence,
        and making the case that the things you buy should actually belong to you.
      </p>
    </header>

    <section class="content-section" id="content">
      <div class="section-header">
        <h2>// ALL DISPATCHES</h2>
        <div class="section-line"></div>
        <div class="section-count">{sorted.length} ENTRIES</div>
      </div>

      {sorted.length > 0 ? (
        <div class="content-grid">
          {sorted.map((entry) => (
            <a href={`/dispatches/${entry.id.replace(/\.md$/, '')}`} class="card">
              <div class="card-thumb">
                {entry.data.youtubeId ? (
                  <img
                    src={`https://img.youtube.com/vi/${entry.data.youtubeId}/maxresdefault.jpg`}
                    alt={entry.data.title}
                    loading="lazy"
                  />
                ) : (
                  <div class="thumb-grid"></div>
                )}
                <div class="thumb-scanlines"></div>

                <div class="thumb-label">dispatch_{entry.data.number}</div>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  <span class="card-date">{entry.data.date}</span>
                </div>
                <h2 class="card-title">{entry.data.title}</h2>
                <p class="card-desc">{entry.data.desc}</p>
                <div class="card-footer">
                  <span class="dot">■</span> watch
                  <span class="dot">■</span> read
                  <span class="dot">■</span> dispatch_{entry.data.number}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-title">// NO ENTRIES YET</div>
          <p>Check back soon — dispatches are being written.</p>
        </div>
      )}
    </section>

    <div class="other-types">
      <div class="section-header">
        <h2>// EXPLORE OTHER TYPES</h2>
        <div class="section-line"></div>
      </div>
      <div class="type-links">
        <a href="/signals" class="type-link">📡 SIGNALS</a>
        <a href="/protocols" class="type-link">⚙️ PROTOCOLS</a>
        <a href="/artifacts" class="type-link">📼 ARTIFACTS</a>
        <a href="/intercepts" class="type-link">👁️ INTERCEPTS</a>
      </div>
    </div>

  </div>

</Base>