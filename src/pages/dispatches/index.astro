---
import Base from '../../layouts/Base.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('dispatches');
---

<Base title="Dispatches" description="Field reports from the right to repair front.">
  <CategoryIndex
    {entries}
    title="DISPATCHES"
    desc="Field reports from the right to repair front. Fixing gear, fighting planned obsolescence, and making the case that the things you buy should actually belong to you."
    emoji="🛠️"
    typeSlug="dispatches"
    otherTypes={[
      { slug: 'signals', emoji: '📡', label: 'SIGNALS' },
      { slug: 'protocols', emoji: '⚙️', label: 'PROTOCOLS' },
      { slug: 'intercepts', emoji: '👁️', label: 'INTERCEPTS' },
      { slug: 'artifacts', emoji: '📼', label: 'ARTIFACTS' },
    ]}
  />
</Base>