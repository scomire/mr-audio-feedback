---
import Search from './Search.astro';
const { pathname } = Astro.url;
---
<a href="#main" class="skip-link">Skip to content</a>

<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="nav-logo">MR. AUDIO <span>FEEDBACK</span></a>
      <ul class="nav-links">
        <li><a href="/" class={pathname === '/' ? 'nav-active' : ''}>_HOME</a></li>
        <li class="nav-dropdown">
          <span class="nav-dropdown-trigger">_CATEGORIES</span>
          <ul class="nav-dropdown-menu">
            <li><a href="/signals">📡 SIGNALS</a></li>
            <li><a href="/protocols">⚙️ PROTOCOLS</a></li>
            <li><a href="/intercepts">👁️ INTERCEPTS</a></li>
            <li><a href="/artifacts">📼 ARTIFACTS</a></li>
            <li><a href="/dispatches">🛠️ DISPATCHES</a></li>
          </ul>
        </li>
        <li><a href="/about" class={pathname === '/about' ? 'nav-active' : ''}>_ABOUT</a></li>
        <li><a href="/rss.xml">_RSS</a></li>
        <li><a href="https://youtube.com/@mraudiofeedback" target="_blank" aria-label="Mr. Audio Feedback on YouTube (opens in new tab)">_YOUTUBE</a></li>
      </ul>
      <Search />
    </div>
  </div>
</nav>

<style>
  .nav-active {
  background: var(--text-dim);
  color: var(--bg2) !important;
  padding: 2px 8px;
}
  
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    color: var(--text-dim);
    font-size: 16px;
    letter-spacing: 1px;
    cursor: url('/cursors/cursor-hand.png') 8 0, pointer;
    transition: color 0.2s;
  }

  .nav-dropdown-trigger::before {
    content: '> ';
    color: var(--amber);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .nav-dropdown:hover .nav-dropdown-trigger {
    color: var(--amber);
  }

  .nav-dropdown:hover .nav-dropdown-trigger::before {
    opacity: 1;
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: rgba(7,7,5,0.98);
    border: 1px solid var(--amber-dim);
    list-style: none;
    padding: 8px 0;
    min-width: 200px;
    z-index: 200;
    margin-top: 0;
    padding-top: 12px;
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    display: block;
  }

  .nav-dropdown-menu li a {
    display: block;
    padding: 8px 20px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 1px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-dropdown-menu li a:hover {
    color: var(--amber);
    background: var(--amber-glow);
  }
</style>