---
---
<div class="search-wrapper">
  <div id="search"></div>
</div>
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showImages: false,
      resetStyles: true,
    });
  });
</script>
<style>
  .search-wrapper {
    position: relative;
    width: 250px;
    --pagefind-ui-text: var(--amber);
    --pagefind-ui-primary: var(--amber);
    --pagefind-ui-background: var(--bg2);
    --pagefind-ui-border: var(--amber-dim);
  }

  .search-wrapper :global(.pagefind-ui__form) {
    position: relative;
  }

  .search-wrapper :global(.pagefind-ui__search-input) {
    background: var(--bg2);
    border: 1px solid var(--amber-dim);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    padding: 4px 12px 4px 40px;
    width: 100%;
    outline: none;
  }

  .search-wrapper :global(.pagefind-ui__search-input:focus) {
    border-color: var(--amber);
  }

  .search-wrapper :global(.pagefind-ui__search-input::placeholder) {
    color: var(--text) !important;
    opacity: 1;
  }

  .search-wrapper :global(.pagefind-ui__search-clear) {
    display: none;
  }

  .search-wrapper :global(.pagefind-ui__form::before) {
    background-color: var(--amber) !important;
    opacity: 1 !important;
  }

  .search-wrapper :global(.pagefind-ui__results) {
    position: absolute;
    top: 100%;
    right: 0;
    width: 400px;
    background: rgba(7,7,5,0.98);
    border: 1px solid var(--amber-dim);
    z-index: 200;
    max-height: 400px;
    overflow-y: auto;
    padding: 8px;
  }

  .search-wrapper :global(.pagefind-ui__result) {
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255,183,0,0.08);
  }

  .search-wrapper :global(.pagefind-ui__result-link) {
    color: var(--amber) !important;
    text-decoration: none;
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
  }

  .search-wrapper :global(.pagefind-ui__result-excerpt) {
    color: var(--text);
    font-size: 13px;
    margin-top: 4px;
  }

  .search-wrapper :global(.pagefind-ui__message) {
    color: var(--text);
    font-size: 13px;
    padding: 12px 20px;
    font-family: 'Share Tech Mono', monospace;
  }
</style>